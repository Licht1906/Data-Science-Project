# ============================================================
# .env.example — N1: Copy file này thành .env rồi điền giá trị thật
# KHÔNG commit file .env vào Git
# ============================================================

# ----------------------------------------------------------
# PostgreSQL root (dùng để tạo DB/user con khi init)
# ----------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ----------------------------------------------------------
# Database dữ liệu Tiki (N2, N3, N4, N5 dùng)
# Airflow connection id: tiki_data
# ----------------------------------------------------------
TIKI_DB_NAME=tiki_data
TIKI_DB_USER=tiki_user
TIKI_DB_PASSWORD=change_me_tiki

# ----------------------------------------------------------
# Database Airflow metadata
# ----------------------------------------------------------
AIRFLOW_DB_NAME=airflow
AIRFLOW_DB_USER=airflow_user
AIRFLOW_DB_PASSWORD=change_me_airflow

# ----------------------------------------------------------
# Airflow config
# Tạo Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ----------------------------------------------------------
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_webserver_secret_key_here
AIRFLOW_WEBSERVER_PORT=8080

# Tài khoản admin Airflow UI
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# ----------------------------------------------------------
# FastAPI (N2)
# ----------------------------------------------------------
API_PORT=8000
MODEL_PATH=models/fake_review_model.pkl

# ----------------------------------------------------------
# Streamlit (N6)
# ----------------------------------------------------------
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000
